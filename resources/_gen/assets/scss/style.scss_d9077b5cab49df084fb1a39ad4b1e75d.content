/*=================================================================
  Modern Blog Listing Styles
==================================================================*/
.blog {
  background: #ffffff;
  padding: 60px 0;
  min-height: 100vh; }
  .blog .container {
    max-width: 1400px; }
    @media (max-width: 992px) {
      .blog .container {
        max-width: 1200px; } }
    @media (max-width: 768px) {
      .blog .container {
        max-width: 100%;
        padding: 0 20px; } }
.blog-header {
  text-align: center;
  margin-bottom: 80px;
  padding: 0px 0 40px 0;
  position: relative; }
  .blog-header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, transparent, #f53f3f, transparent);
    border-radius: 2px; }
  .blog-header .blog-title {
    font-family: 'Georgia', serif !important;
    font-size: 48px !important;
    font-weight: 400 !important;
    color: #000000 !important;
    margin: 0 0 16px 0 !important;
    letter-spacing: -0.02em !important; }
    @media (max-width: 768px) {
      .blog-header .blog-title {
        font-size: 36px !important; } }
    @media (max-width: 480px) {
      .blog-header .blog-title {
        font-size: 28px !important; } }
  .blog-header .blog-subtitle {
    font-size: 18px !important;
    color: #333333 !important;
    margin: 0 !important;
    font-weight: 400 !important;
    line-height: 1.6 !important; }
    @media (max-width: 768px) {
      .blog-header .blog-subtitle {
        font-size: 16px !important; } }
.blog .blog-header .blog-title,
.page-wrapper .blog-header .blog-title,
.container .blog-header .blog-title {
  color: #000000 !important; }

.blog .blog-header .blog-subtitle,
.page-wrapper .blog-header .blog-subtitle,
.container .blog-header .blog-subtitle {
  color: #333333 !important; }

.post {
  background: #fafafa;
  margin-bottom: 40px;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 4px -1px rgba(0, 0, 0, 0.06), 0 1px 2px -1px rgba(0, 0, 0, 0.04);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1px solid rgba(0, 0, 0, 0.08); }
  .post:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 12px -2px rgba(0, 0, 0, 0.1), 0 4px 6px -1px rgba(0, 0, 0, 0.06);
    border-color: rgba(245, 63, 63, 0.2);
    background: #ffffff; }
  @media (max-width: 768px) {
    .post {
      margin-bottom: 24px;
      border-radius: 12px; } }
  .post .post-container {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 0;
    min-height: 220px; }
    @media (max-width: 768px) {
      .post .post-container {
        grid-template-columns: 1fr;
        gap: 0; } }
  .post .post-media {
    position: relative;
    overflow: hidden; }
    .post .post-media.post-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      min-height: 220px; }
    .post .post-media.post-thumb a {
      display: block;
      height: 100%;
      position: relative; }
      .post .post-media.post-thumb a::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(45deg, rgba(245, 63, 63, 0.1), rgba(245, 63, 63, 0.15));
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 1; }
      .post .post-media.post-thumb a:hover::before {
        opacity: 1; }
      .post .post-media.post-thumb a:hover img {
        transform: scale(1.05); }
    .post .post-media.post-media-audio iframe {
      width: 100%;
      height: 220px; }
  .post .post-content-wrapper {
    padding: 32px 36px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: inherit; }
    @media (max-width: 768px) {
      .post .post-content-wrapper {
        padding: 24px 20px; } }
  .post .post-title {
    margin: 0 0 16px 0;
    font-family: 'Georgia', serif;
    font-size: 24px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.025em; }
    @media (max-width: 768px) {
      .post .post-title {
        font-size: 20px;
        margin-bottom: 12px; } }
    .post .post-title a {
      color: #1e293b;
      text-decoration: none;
      background: linear-gradient(120deg, transparent 0%, transparent 95%, #f53f3f 95%);
      background-size: 0% 100%;
      background-repeat: no-repeat;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
      .post .post-title a:hover {
        color: #f53f3f;
        background-size: 100% 100%;
        background-image: linear-gradient(120deg, transparent 0%, transparent 95%, rgba(245, 63, 63, 0.1) 95%); }
  .post .post-meta {
    margin: 0 0 20px 0;
    font-size: 13px; }
    .post .post-meta ul {
      display: flex;
      flex-wrap: wrap;
      gap: 24px;
      margin: 0;
      padding: 0;
      list-style: none; }
      @media (max-width: 768px) {
        .post .post-meta ul {
          gap: 16px;
          flex-direction: column; } }
      .post .post-meta ul li {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #64748b;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.025em;
        margin: 0; }
        .post .post-meta ul li i {
          color: #f53f3f;
          font-size: 12px;
          width: 14px;
          text-align: center; }
        .post .post-meta ul li a {
          color: #64748b;
          text-decoration: none;
          transition: color 0.2s ease;
          font-weight: 600; }
          .post .post-meta ul li a:hover {
            color: #f53f3f; }
    .post .post-meta .post-author {
      color: #1e293b;
      font-weight: 600; }
  .post .post-content {
    flex-grow: 1;
    margin: 0; }
    .post .post-content p {
      line-height: 1.7;
      color: #475569;
      font-size: 15px;
      margin: 0 0 20px 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden; }
    .post .post-content ul, .post .post-content ol {
      font-size: 15px;
      padding: 0 0 0 20px;
      margin: 16px 0;
      color: #475569;
      line-height: 1.6; }
    .post .post-content ul {
      list-style-type: disc; }
    .post .post-content blockquote {
      margin: 20px 0;
      padding: 20px 24px;
      font-size: 16px;
      font-style: italic;
      background: #f5f5f5;
      border-left: 4px solid #f53f3f;
      border-radius: 0 8px 8px 0;
      color: #374151;
      position: relative; }
      .post .post-content blockquote::before {
        content: '"';
        position: absolute;
        top: -10px;
        left: 16px;
        font-size: 48px;
        color: #f53f3f;
        opacity: 0.3;
        font-family: Georgia, serif; }
    .post .post-content .btn-main, .post .post-content .btn-transparent, .post .post-content .btn-small {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      margin: 0;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.025em;
      text-transform: uppercase;
      background: #f53f3f;
      color: white;
      border: none;
      border-radius: 8px;
      text-decoration: none;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 6px -1px rgba(245, 63, 63, 0.3); }
      .post .post-content .btn-main:hover, .post .post-content .btn-transparent:hover, .post .post-content .btn-small:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 15px -3px rgba(245, 63, 63, 0.4);
        background: #e02d2d;
        color: white; }
      .post .post-content .btn-main:active, .post .post-content .btn-transparent:active, .post .post-content .btn-small:active {
        transform: translateY(0);
        box-shadow: 0 4px 6px -1px rgba(245, 63, 63, 0.3); }
      .post .post-content .btn-main::after, .post .post-content .btn-transparent::after, .post .post-content .btn-small::after {
        content: '→';
        transition: transform 0.2s ease; }
      .post .post-content .btn-main:hover::after, .post .post-content .btn-transparent:hover::after, .post .post-content .btn-small:hover::after {
        transform: translateX(4px); }

.post-pagination {
  margin: 60px 0 0 0;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px; }
  @media (max-width: 992px) {
    .post-pagination {
      margin-bottom: 60px; } }
  @media (max-width: 768px) {
    .post-pagination {
      margin: 40px 0 25px 0;
      gap: 4px; } }
  .post-pagination li {
    margin: 0;
    display: inline-block; }
    .post-pagination li a {
      display: flex;
      align-items: center;
      justify-content: center;
      min-width: 44px;
      height: 44px;
      padding: 0 16px;
      color: #64748b;
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
      .post-pagination li a:hover {
        color: #f53f3f;
        background: #f8f9fa;
        border-color: #f53f3f;
        transform: translateY(-1px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
    .post-pagination li.active a {
      background: #f53f3f;
      border-color: #f53f3f;
      color: white;
      box-shadow: 0 4px 6px -1px rgba(245, 63, 63, 0.3); }
      .post-pagination li.active a:hover {
        background: #e02d2d;
        transform: translateY(-1px);
        box-shadow: 0 6px 8px -1px rgba(245, 63, 63, 0.4); }
  .post-pagination li:first-child a,
  .post-pagination li:last-child a {
    border-radius: 8px; }

@keyframes shimmer {
  0% {
    background-position: -468px 0; }
  100% {
    background-position: 468px 0; } }

.post-media.loading {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 400% 100%;
  animation: shimmer 1.2s ease-in-out infinite; }

@media (max-width: 768px) {
  .blog {
    padding: 40px 0; }
  .post .post-container {
    grid-template-columns: 1fr; }
  .post .post-media.post-thumb img {
    min-height: 180px; } }

.coming-soon {
  background: url("../images/backgrounds/coming-soon.jpg");
  background-repeat: no-repeat;
  background-size: cover;
  color: #ffffff;
  display: flex;
  align-items: center;
  height: 100vh; }
  @media (max-width: 400px) {
    .coming-soon {
      padding: 50px 0; } }
  @media (max-width: 480px) {
    .coming-soon {
      padding: 50px 0; } }
  .coming-soon .block h1 {
    line-height: 65px;
    font-size: 55px;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0; }
    @media (max-width: 400px) {
      .coming-soon .block h1 {
        font-size: 40px;
        line-height: 50px; } }
    @media (max-width: 480px) {
      .coming-soon .block h1 {
