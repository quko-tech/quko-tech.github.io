@charset "UTF-8";
/*=== MEDIA QUERY ===*/
body {
  line-height: 1.7;
  font-family: "Inter", sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  font-feature-settings: "kern" 1, "liga" 1;
  color: #626b78; }

h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: "Inter", sans-serif;
  color: #12151c;
  line-height: 1.3; }

h1,
h2 {
  font-weight: 700; }

h3,
h4 {
  font-weight: 600; }

h5,
h6 {
  font-weight: 500; }

h1 {
  font-size: 40px; }
  @media (max-width: 768px) {
    h1 {
      font-size: 34px; } }
  @media (max-width: 480px) {
    h1 {
      font-size: 28px; } }
  @media (max-width: 400px) {
    h1 {
      font-size: 26px; } }
h2 {
  font-size: 28px; }
  @media (max-width: 480px) {
    h2 {
      font-size: 22px; } }
h3 {
  font-size: 20px; }

h4 {
  font-size: 18px; }

p {
  color: #626b78;
  font-size: 16px;
  font-family: "Inter", sans-serif;
  line-height: 1.7; }

ul {
  margin: 0;
  padding-left: 0;
  list-style-type: none; }

iframe {
  border: 0; }

img {
  max-width: 100%;
  height: auto; }

a,
a:focus,
a:hover {
  text-decoration: none;
  outline: 0;
  color: #e8383f;
  -webkit-transition: all 0.3s ease;
  -moz-transition: all 0.3s ease;
  -ms-transition: all 0.3s ease;
  -o-transition: all 0.3s ease;
  transition: all 0.3s ease; }

blockquote {
  font-size: 18px;
  border-color: #e8383f;
  padding: 20px 40px;
  text-align: left;
  color: #737373;
  border-left: 4px solid #e8383f;
  border-radius: 0 8px 8px 0;
  background: rgba(232, 56, 63, 0.04); }

.navbar-toggle .icon-bar {
  background: #e8383f; }

input[type="email"],
input[type="password"],
input[type="text"],
input[type="tel"] {
  box-shadow: none;
  height: 50px;
  outline: none;
  font-size: 15px;
  border-radius: 8px;
  padding: 10px 18px;
  border: 1px solid #dfe3e8;
  -webkit-transition: all 0.3s ease;
  -moz-transition: all 0.3s ease;
  -ms-transition: all 0.3s ease;
  -o-transition: all 0.3s ease;
  transition: all 0.3s ease; }
  input[type="email"]:focus,
  input[type="password"]:focus,
  input[type="text"]:focus,
  input[type="tel"]:focus {
    box-shadow: 0 0 0 3px rgba(232, 56, 63, 0.15);
    border: 1px solid #e8383f; }

.form-control {
  box-shadow: none;
  border-radius: 8px; }
  .form-control:focus {
    box-shadow: 0 0 0 3px rgba(232, 56, 63, 0.15);
    border: 1px solid #e8383f; }

.slick-slide {
  outline: 0; }

.btn-main, .btn-small, .btn-transparent {
  background: #e8383f;
  color: #ffffff;
  display: inline-block;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.5px;
  padding: 14px 36px;
  text-transform: uppercase;
  border-radius: 8px;
  border: 2px solid #e8383f;
  box-shadow: 0 4px 15px rgba(232, 56, 63, 0.3);
  -webkit-transition: all 0.3s ease;
  -moz-transition: all 0.3s ease;
  -ms-transition: all 0.3s ease;
  -o-transition: all 0.3s ease;
  transition: all 0.3s ease; }
  .btn-main.btn-icon i, .btn-icon.btn-small i, .btn-icon.btn-transparent i {
    font-size: 16px;
    vertical-align: middle;
    margin-right: 5px; }
  .btn-main:hover, .btn-small:hover, .btn-transparent:hover {
    background: #d41920;
    border-color: #d41920;
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(232, 56, 63, 0.4); }
  .btn-main:active, .btn-small:active, .btn-transparent:active {
    transform: translateY(0);
    box-shadow: 0 2px 10px rgba(232, 56, 63, 0.3); }

.btn-solid-border {
  border: 2px solid #ffffff;
  background: transparent;
  color: #ffffff;
  border-radius: 8px; }
  .btn-solid-border:hover {
    border: 2px solid #e8383f;
    background: #e8383f;
    box-shadow: 0 4px 15px rgba(232, 56, 63, 0.3); }

.btn-transparent {
  background: transparent;
  padding: 0;
  color: #e8383f;
  box-shadow: none;
  border: none; }
  .btn-transparent:hover {
    background: transparent;
    color: #d41920;
    box-shadow: none;
    transform: none; }

.btn-large {
  padding: 20px 45px; }
  .btn-large.btn-icon i {
    font-size: 16px;
    vertical-align: middle;
    margin-right: 5px; }

.btn-small {
  padding: 10px 25px;
  font-size: 12px; }

.btn-round {
  border-radius: 8px; }

.btn-round-full {
  border-radius: 50px; }

.btn.active:focus,
.btn:active:focus,
.btn:focus {
  outline: 0; }

.mt-10 {
  margin-top: 20px; }

.mt-20 {
  margin-top: 20px; }

.mt-30 {
  margin-top: 30px; }

.mt-40 {
  margin-top: 40px; }

.mt-50 {
  margin-top: 50px; }

.btn:focus {
  color: #d9d9d9; }

.w-100 {
  width: 100%; }

.margin-0 {
  margin: 0 !important; }

/* preloader */
.preloader {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center; }

.bg-shadow {
  background-color: #ffffff;
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
  padding: 20px;
  border-radius: 12px; }

.bg-gray {
  background: #f5f5f5; }

.bg-primary {
  background: #e8383f; }

.bg-primary-dark {
  background: #d41920; }

.bg-primary-darker {
  background: #a71319; }

.bg-dark {
  background: #1a1a2e; }

.section {
  padding: 100px 0; }
  @media (max-width: 768px) {
    .section {
      padding-top: 60px;
      padding-bottom: 60px; } }
.section-sm {
  padding: 70px 0; }

.title {
  padding: 20px 0 30px; }
  .title h2 {
    font-size: 18px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 2px; }

.section-title {
  margin-bottom: 60px; }
  @media (max-width: 768px) {
    .section-title {
      margin-bottom: 30px; } }
  .section-title h2 {
    font-size: 32px;
    font-weight: 700;
    margin: 0px;
    padding: 15px 0px;
    letter-spacing: -0.02em; }
    @media (max-width: 480px) {
      .section-title h2 {
        font-size: 26px; } }
  .section-title p {
    font-size: 18px;
    color: #7b8490;
    padding: 10px 0px;
    font-family: "Inter", sans-serif;
    max-width: 600px; }
    @media (max-width: 480px) {
      .section-title p {
        font-size: 16px; } }
.section-subtitle {
  font-size: 28px;
  font-weight: 700;
  margin-bottom: 30px;
  letter-spacing: -0.02em; }
  @media (max-width: 400px) {
    .section-subtitle {
      font-size: 26px; } }
  @media (max-width: 480px) {
    .section-subtitle {
      font-size: 24px; } }
.page-title {
  padding: 120px 0; }
  .page-title .block {
    text-align: center; }
    .page-title .block h1 {
      color: #ffffff;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-top: 0;
      font-size: 42px; }
      @media (max-width: 480px) {
        .page-title .block h1 {
          font-size: 32px; } }
    .page-title .block p {
      color: rgba(255, 255, 255, 0.85);
      font-size: 18px;
      max-width: 600px;
      margin: 0 auto; }

.heading {
  padding-bottom: 60px;
  text-align: center; }
  .heading h2 {
    color: #12151c;
    font-size: 32px;
    line-height: 1.3;
    font-weight: 700; }
  .heading p {
    font-size: 18px;
    line-height: 1.7;
    color: #7b8490;
    font-weight: 400;
    max-width: 600px;
    margin: 0 auto; }

.page-wrapper {
  padding: 70px 0; }
  @media (max-width: 768px) {
    .page-wrapper {
      padding-top: 40px;
      padding-bottom: 40px; } }
.social-media-icons ul li {
  display: inline-block; }
  .social-media-icons ul li a {
    font-size: 18px;
    display: inline-block;
    padding: 7px 12px;
    color: #ffffff;
    border-radius: 6px;
    -webkit-transition: all 0.3s ease;
    -moz-transition: all 0.3s ease;
    -ms-transition: all 0.3s ease;
    -o-transition: all 0.3s ease;
    transition: all 0.3s ease; }
    .social-media-icons ul li a:hover {
      transform: translateY(-2px); }
  .social-media-icons ul li .twitter {
    background: #00aced; }
  .social-media-icons ul li .facebook {
    background: #3b5998;
    padding: 7px 18px; }
  .social-media-icons ul li .googleplus {
    background: #dd4b39; }
  .social-media-icons ul li .dribbble {
    background: #ea4c89; }
  .social-media-icons ul li .instagram {
    background: #bc2a8d; }

.dropdown-slide {
  position: static; }
  .dropdown-slide .open > a,
  .dropdown-slide .open > a:focus,
  .dropdown-slide .open > a:hover {
    background: transparent; }
  .dropdown-slide.full-width .dropdown-menu {
    left: 0 !important;
    right: 0 !important; }
  .dropdown-slide:hover .dropdown-menu {
    display: none;
    opacity: 1;
    display: block;
    transform: translate(0px, 0px);
    opacity: 1;
    visibility: visible;
    color: #737373;
    transform: translateY(0px); }
  .dropdown-slide .dropdown-menu {
    border-radius: 10px;
    opacity: 1;
    visibility: visible;
    position: absolute;
    padding: 10px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    position: absolute;
    display: block;
    visibility: hidden;
    opacity: 0;
    transform: translateY(15px);
    transition: visibility 0.3s, opacity 0.3s, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    @media (max-width: 480px) {
      .dropdown-slide .dropdown-menu {
        transform: none; } }
.commonSelect {
  margin-left: 10px;
  padding-right: 6px;
  position: relative; }
  .commonSelect:before {
    content: '\f3d0';
    font-family: "Font Awesome 5 Free";
    position: absolute;
    right: -4px;
    top: 4px;
    font-size: 10px; }
  .commonSelect select {
    -webkit-appearance: none;
    -moz-appearance: none;
    cursor: pointer;
    border: none;
    padding: 0;
    height: auto;
    color: #555555; }
    .commonSelect select:focus {
      box-shadow: none;
      border: none; }

.tabCommon .nav-tabs {
  border-bottom: 0;
  margin-bottom: 10px; }
  .tabCommon .nav-tabs li {
    margin-right: 5px; }
  .tabCommon .nav-tabs li.active a {
    background-color: #e8383f;
    border: 1px solid #e8383f;
    color: #ffffff;
    border-radius: 8px; }
  .tabCommon .nav-tabs a {
    border-radius: 8px;
    background: #f5f5f5;
    -webkit-transition: all 0.3s ease;
    -moz-transition: all 0.3s ease;
    -ms-transition: all 0.3s ease;
    -o-transition: all 0.3s ease;
    transition: all 0.3s ease; }
    .tabCommon .nav-tabs a:hover {
      border: 1px solid transparent;
      background: #e8383f;
      color: #ffffff; }

.tabCommon .tab-content {
  padding: 20px;
  border: 1px solid #dfe3e8;
  border-radius: 12px; }

.commonAccordion .panel, .commonAccordion-2 .panel {
  border-radius: 12px;
  box-shadow: none; }
  .commonAccordion .panel .panel-heading, .commonAccordion-2 .panel .panel-heading {
    background: transparent;
    padding: 0; }
  .commonAccordion .panel .panel-title, .commonAccordion-2 .panel .panel-title {
    position: relative; }
    .commonAccordion .panel .panel-title a, .commonAccordion-2 .panel .panel-title a {
      display: block;
      font-size: 14px;
      text-transform: uppercase;
      padding: 10px 10px; }
    .commonAccordion .panel .panel-title a:before, .commonAccordion-2 .panel .panel-title a:before {
      color: #555555;
      content: "\f209";
      position: absolute;
      right: 25px;
      font-family: "Font Awesome 5 Free"; }
    .commonAccordion .panel .panel-title a.collapsed:before, .commonAccordion-2 .panel .panel-title a.collapsed:before {
      content: "\f217"; }

.list-circle {
  padding-left: 20px; }
  .list-circle li {
    list-style-type: circle; }

.play-icon {
  border: 2px solid #dfe3e8;
  display: inline-block;
  width: 60px;
  height: 60px;
  border-radius: 50px;
  font-size: 30px;
  -webkit-transition: all 0.3s ease;
  -moz-transition: all 0.3s ease;
  -ms-transition: all 0.3s ease;
  -o-transition: all 0.3s ease;
  transition: all 0.3s ease; }
  .play-icon i {
    line-height: 60px; }
  .play-icon:hover {
    background: #e8383f;
    border-color: #e8383f;
    color: #ffffff;
    transform: scale(1.1); }

.alert-common {
  border-radius: 8px;
  border-width: 2px; }
  .alert-common i {
    margin: 0 5px;
    font-size: 16px; }

.alert-solid {
  background: transparent;
  color: #e8383f; }

@media (max-width: 480px) {
  .buttonPart li {
    margin-bottom: 8px; } }

@media (max-width: 768px) {
  .buttonPart li {
    margin-bottom: 8px; } }

.overly, .page-title {
  position: relative; }
  .overly:before, .page-title:before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    right: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #790e12 0%, #be161d 50%, rgba(232, 56, 63, 0.85) 100%);
    opacity: 0.88; }

.owl-dots .owl-dot.active span,
.owl-theme .owl-dots .owl-dot:hover span {
  background: #e8383f !important; }

#success,
#error {
  display: none; }

.sticky-top {
  position: sticky;
  top: 0;
  z-index: 1100; }
  @media (max-width: 992px) {
    .sticky-top {
      position: static; } }
span.cloaked-e-mail:before {
  content: attr(data-domain) "@" attr(data-user);
  unicode-bidi: bidi-override;
  direction: rtl; }

@media (min-width: 992px) {
  .row .no-float {
    display: table-cell;
    float: none; } }

/* ==========================================================================
   Mobile-Specific Styles
   ========================================================================== */
@media (max-width: 768px) {
  .section {
    padding: 60px 0; }
  .section-sm {
    padding: 40px 0; }
  .page-title {
    padding: 80px 0; }
  .page-wrapper {
    padding: 40px 0; }
  .bg-shadow {
    padding: 15px; }
  .mt-50 {
    margin-top: 30px; }
  .mt-40 {
    margin-top: 25px; }
  .mt-30 {
    margin-top: 20px; }
  .section-title h2 {
    font-size: 1.8em;
    padding: 10px 0px; }
  .section-title p {
    font-size: 1em; }
  .section-subtitle {
    font-size: 22px;
    margin-bottom: 20px; }
  .heading h2 {
    font-size: 24px;
    line-height: 1.4; }
  .heading p {
    font-size: 16px;
    line-height: 1.6;
    padding: 0 10px; }
  blockquote {
    font-size: 16px;
    padding: 15px 25px; }
  .page-title .block h1 {
    font-size: 2em;
    letter-spacing: -0.01em; }
  .btn-main, .btn-transparent, .btn-small,
  .btn-large {
    padding: 12px 25px;
    font-size: 13px; }
  .btn-large {
    padding: 15px 35px; }
  .dropdown-slide:hover .dropdown-menu,
  .dropdown-slide .dropdown-menu {
    transform: none;
    width: 100%;
    position: relative;
    box-shadow: none;
    border: none;
    visibility: visible;
    opacity: 1;
    display: none; }
  .tabCommon .nav-tabs li {
    display: block;
    width: 100%;
    margin-right: 0;
    margin-bottom: 5px; }
  .tabCommon .nav-tabs li a {
    text-align: center; }
  .social-media-icons ul li a {
    padding: 5px 10px;
    font-size: 16px; }
  .social-media-icons ul li .facebook {
    padding: 5px 15px; }
  .sticky-top {
    position: sticky;
    top: 0; } }

@media (max-width: 480px) {
  .section-title h2 {
    font-size: 1.5em; }
  .page-title .block h1 {
    font-size: 1.7em; }
  .btn-main, .btn-transparent,
  .btn-large,
  .btn-small {
    padding: 12px 24px;
    width: auto;
    display: inline-block;
    text-align: center; } }

#wrapper-work {
  overflow: hidden;
  padding-top: 100px; }
  #wrapper-work ul li {
    width: 50%;
    float: left;
    position: relative; }
    #wrapper-work ul li img {
      width: 100%;
      height: 100%; }
    #wrapper-work ul li .items-text {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      height: 100%;
      color: #ffffff;
      background: rgba(0, 0, 0, 0.6);
      padding-left: 44px;
      padding-top: 140px; }
      #wrapper-work ul li .items-text h2 {
        padding-bottom: 28px;
        padding-top: 75px;
        position: relative; }
        #wrapper-work ul li .items-text h2:before {
          content: "";
          position: absolute;
          left: 0;
          bottom: 0;
          width: 75px;
          height: 3px;
          background: #ffffff; }
      #wrapper-work ul li .items-text p {
        padding-top: 30px;
        font-size: 16px;
        line-height: 27px;
        font-weight: 300;
        padding-right: 80px; }

/*--
  features-work Start 
--*/
#features-work {
  padding-top: 50px;
  padding-bottom: 75px; }
  #features-work .block ul li {
    width: 19%;
    text-align: center;
    display: inline-block;
    padding: 40px 0px; }

/*--
  Header Start
--*/
header {
  min-height: 80px;
  background: #ffffff;
  padding: 10px 0;
  -webkit-transition: all 0.3s ease;
  -moz-transition: all 0.3s ease;
  -ms-transition: all 0.3s ease;
  -o-transition: all 0.3s ease;
  transition: all 0.3s ease; }
  @media (max-width: 992px) {
    header {
      min-height: 70px; } }
  header .navbar {
    margin-bottom: 0px;
    border: 0px; }
  header .navbar-brand {
    padding-top: 5px; }
  header .navbar-default {
    background: none;
    border: 0px; }
    header .navbar-default .navbar-nav {
      padding-top: 10px; }
      header .navbar-default .navbar-nav li a {
        color: #7b8490;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 500;
        -webkit-transition: all 0.3s ease;
        -moz-transition: all 0.3s ease;
        -ms-transition: all 0.3s ease;
        -o-transition: all 0.3s ease;
        transition: all 0.3s ease; }
        header .navbar-default .navbar-nav li a:hover {
          color: #e8383f; }

.navigation {
  background: #ffffff;
  padding: 10px 0;
  box-shadow: 0 1px 15px rgba(0, 0, 0, 0.06);
  z-index: 1100;
  position: relative;
  -webkit-transition: all 0.3s ease;
  -moz-transition: all 0.3s ease;
  -ms-transition: all 0.3s ease;
  -o-transition: all 0.3s ease;
  transition: all 0.3s ease; }
  .navigation .navbar {
    margin-bottom: 0px;
    border: 0px; }
  .navigation .navbar-brand {
    padding-top: 5px; }
    .navigation .navbar-brand img {
      height: auto;
      width: auto;
      -webkit-transition: all 0.3s ease;
      -moz-transition: all 0.3s ease;
      -ms-transition: all 0.3s ease;
      -o-transition: all 0.3s ease;
      transition: all 0.3s ease; }
      @media (max-width: 992px) {
        .navigation .navbar-brand img {
          max-height: 40px;
          width: auto; } }
  .navigation .navbar {
    background: none;
    border: 0px; }
    .navigation .navbar .navbar-nav {
      padding-top: 8px; }
      .navigation .navbar .navbar-nav a {
        color: #626b78;
        padding: 10px 18px;
        position: relative;
        font-weight: 500;
        font-size: 14px;
        letter-spacing: 0.3px;
        -webkit-transition: all 0.3s ease;
        -moz-transition: all 0.3s ease;
        -ms-transition: all 0.3s ease;
        -o-transition: all 0.3s ease;
        transition: all 0.3s ease; }
        .navigation .navbar .navbar-nav a:hover, .navigation .navbar .navbar-nav a:focus {
          color: #e8383f;
          background: transparent; }
      .navigation .navbar .navbar-nav a.current {
        color: #e8383f;
        pointer-events: none;
        cursor: default; }
      .navigation .navbar .navbar-nav a.current-parent {
        color: #e8383f; }
      .navigation .navbar .navbar-nav select {
        margin: 10px 15px;
        border-radius: 6px;
        padding: 4px 8px;
        border: 1px solid #dfe3e8;
        font-size: 13px;
        -webkit-transition: all 0.3s ease;
        -moz-transition: all 0.3s ease;
        -ms-transition: all 0.3s ease;
        -o-transition: all 0.3s ease;
        transition: all 0.3s ease; }
        .navigation .navbar .navbar-nav select:focus {
          border-color: #e8383f;
          outline: none; }
    .navigation .navbar .current > .dropdown-toggle {
      color: #e8383f; }
    .navigation .navbar .dropdown-menu {
      border-radius: 10px;
      border: none;
      left: -5px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
      padding: 8px 0;
      z-index: 1200; }
      .navigation .navbar .dropdown-menu a {
        font-weight: normal;
        color: #626b78;
        padding: 10px 20px;
        font-size: 14px;
        -webkit-transition: all 0.2s ease;
        -moz-transition: all 0.2s ease;
        -ms-transition: all 0.2s ease;
        -o-transition: all 0.2s ease;
        transition: all 0.2s ease; }
        .navigation .navbar .dropdown-menu a:hover {
          background: rgba(232, 56, 63, 0.08);
          color: #e8383f;
          padding-left: 24px; }
      .navigation .navbar .dropdown-menu a.current {
        padding-left: 24px;
        color: #e8383f;
        background: rgba(232, 56, 63, 0.08); }

.nav .open > a {
  background: transparent; }

@media (max-width: 992px) {
  .navbar-header {
    float: none; }
  .navbar-left,
  .navbar-right {
    float: none !important; }
  .navbar-toggle {
    display: block;
    border-radius: 6px;
    border-color: rgba(0, 0, 0, 0.1);
    -webkit-transition: all 0.3s ease;
    -moz-transition: all 0.3s ease;
    -ms-transition: all 0.3s ease;
    -o-transition: all 0.3s ease;
    transition: all 0.3s ease; }
    .navbar-toggle:hover {
      background: rgba(232, 56, 63, 0.05); }
  .navbar-collapse {
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: none; }
  .navbar-fixed-top {
    top: 0;
    border-width: 0 0 1px; }
  .navbar-collapse.collapse {
    display: none !important; }
  .navbar-nav {
    float: none !important;
    margin-top: 7.5px; }
  .navbar-nav > li {
    float: none; }
  .navbar-nav > li > a {
    padding-top: 10px;
    padding-bottom: 10px; }
  .collapse {
    clear: both; }
  .collapse.in {
    display: block !important; } }

.slider {
  background-repeat: no-repeat;
  background-size: cover;
  background-attachment: fixed;
  background-position: center center;
  padding: 180px 0 200px;
  position: relative; }
  @media (max-width: 1200px) {
    .slider {
      background-attachment: scroll;
      padding: 150px 0; } }
  @media (max-width: 768px) {
    .slider {
      padding: 120px 0; } }
  @media (max-width: 480px) {
    .slider {
      padding: 100px 0; } }
  .slider .block {
    color: #ffffff;
    text-align: center;
    position: relative;
    z-index: 1; }
    .slider .block h1 {
      font-weight: 700;
      font-size: 52px;
      line-height: 1.2;
      letter-spacing: -0.02em;
      padding-bottom: 20px;
      color: #ffffff; }
      @media (max-width: 768px) {
        .slider .block h1 {
          font-size: 40px; } }
      @media (max-width: 480px) {
        .slider .block h1 {
          font-size: 32px; } }
      @media (max-width: 400px) {
        .slider .block h1 {
          font-size: 28px; } }
    .slider .block p {
      margin-bottom: 35px;
      color: rgba(255, 255, 255, 0.85);
      font-size: 19px;
      line-height: 1.6;
      font-weight: 400;
      max-width: 650px;
      margin-left: auto;
      margin-right: auto; }
      @media (max-width: 480px) {
        .slider .block p {
          font-size: 16px; } }
    .slider .block .btn-main, .slider .block .btn-transparent, .slider .block .btn-small {
      padding: 16px 40px;
      font-size: 14px;
      border-radius: 8px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2); }
      .slider .block .btn-main:hover, .slider .block .btn-transparent:hover, .slider .block .btn-small:hover {
        box-shadow: 0 6px 25px rgba(0, 0, 0, 0.3); }
    @media (max-width: 480px) {
      .slider .block .btn {
        font-size: 13px; } }
.call-to-action {
  text-align: center;
  padding: 90px 0px;
  position: relative;
  z-index: 1; }

.call-to-action h2 {
  color: white;
