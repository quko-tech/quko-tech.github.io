html {
  scroll-behavior: smooth; }

::selection {
  background-color: #f53f3f;
  color: #f3f3f3; }

.bg-1 {
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  background-attachment: fixed; }
  @media (max-width: 1200px) {
    .bg-1 {
      background-attachment: unset; } }
.bg-2 {
  background-size: cover;
  background-position: center center;
  background-attachment: fixed; }
  @media (max-width: 1200px) {
    .bg-2 {
      background-attachment: unset; } }
/*=================================================================
  Modern Blog Sidebar Styles
==================================================================*/
.sidebar {
  padding-left: 40px; }
  @media (max-width: 768px) {
    .sidebar {
      padding-left: 0;
      margin-top: 60px; } }
.widget {
  margin-bottom: 50px;
  background: transparent;
  padding: 0; }
  @media (max-width: 768px) {
    .widget {
      margin-bottom: 40px; } }
  .widget .widget-title {
    font-family: 'Georgia', serif !important;
    margin-top: 0px !important;
    margin-bottom: 24px !important;
    font-size: 20px !important;
    color: #000000 !important;
    font-weight: 600 !important;
    border-bottom: 2px solid #f53f3f !important;
    padding-bottom: 12px !important;
    letter-spacing: -0.01em;
    position: relative; }
    .widget .widget-title::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 40px;
      height: 2px;
      background: #f53f3f;
      border-radius: 1px; }
    @media (max-width: 768px) {
      .widget .widget-title {
        font-size: 18px !important; } }
  .widget.widget-latest-post .media {
    display: flex;
    align-items: flex-start;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08); }
    .widget.widget-latest-post .media:last-child {
      margin-bottom: 0;
      padding-bottom: 0;
      border-bottom: none; }
    .widget.widget-latest-post .media .pull-left {
      margin-right: 16px;
      flex-shrink: 0; }
    .widget.widget-latest-post .media .media-object {
      width: 70px !important;
      height: 70px !important;
      object-fit: cover;
      border-radius: 8px;
      transition: transform 0.3s ease; }
      .widget.widget-latest-post .media .media-object:hover {
        transform: scale(1.05); }
    .widget.widget-latest-post .media .media-body {
      flex: 1;
      min-width: 0; }
    .widget.widget-latest-post .media .media-heading {
      margin-bottom: 8px !important; }
      .widget.widget-latest-post .media .media-heading a {
        color: #000000 !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        line-height: 1.4 !important;
        text-decoration: none !important;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 0.2s ease; }
        .widget.widget-latest-post .media .media-heading a:hover {
          color: #f53f3f !important; }
    .widget.widget-latest-post .media p {
      font-size: 12px !important;
      color: #333333 !important;
      margin: 0 !important;
      line-height: 1.4 !important;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden; }
  .widget.widget-latest-post .media .media-heading a, .widget.widget-latest-post .media .media-body .media-heading a, .widget.widget-latest-post .media .media-body h4 a {
    color: #000000 !important; }
    .widget.widget-latest-post .media .media-heading a:hover, .widget.widget-latest-post .media .media-body .media-heading a:hover, .widget.widget-latest-post .media .media-body h4 a:hover {
      color: #f53f3f !important; }
  .widget.widget-latest-post .media p, .widget.widget-latest-post .media .media-body p {
    color: #333333 !important; }
  .widget.widget-category .widget-category-list {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important; }
    .widget.widget-category .widget-category-list li {
      margin-bottom: 8px; }
      .widget.widget-category .widget-category-list li:last-child {
        margin-bottom: 0; }
      .widget.widget-category .widget-category-list li a {
        display: block !important;
        color: #000000 !important;
        padding: 12px 18px !important;
        background: #ffffff !important;
        border-radius: 8px !important;
        text-decoration: none !important;
        font-size: 14px !important;
        font-weight: 500 !important;
        border: 1px solid rgba(0, 0, 0, 0.1) !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        position: relative;
        overflow: hidden; }
        .widget.widget-category .widget-category-list li a::before {
          content: '→';
          position: absolute;
          right: 18px;
          top: 50%;
          transform: translateY(-50%) translateX(20px);
          opacity: 0;
          transition: all 0.3s ease;
          color: #f53f3f;
          font-weight: bold; }
        .widget.widget-category .widget-category-list li a:hover {
          color: #f53f3f !important;
          background: #ffffff !important;
          border-color: #f53f3f !important;
          transform: translateX(4px) !important;
          box-shadow: 0 2px 8px -1px rgba(245, 63, 63, 0.2); }
          .widget.widget-category .widget-category-list li a:hover::before {
            opacity: 1;
            transform: translateY(-50%) translateX(0); }
        .widget.widget-category .widget-category-list li a:active {
          transform: translateX(2px) !important; }
      .widget.widget-category .widget-category-list li a.current {
        color: #ffffff !important;
        background: #f53f3f !important;
        border-color: #f53f3f !important;
        box-shadow: 0 4px 6px -1px rgba(245, 63, 63, 0.3);
        pointer-events: none;
        cursor: default; }
        .widget.widget-category .widget-category-list li a.current::before {
          opacity: 0; }
  .widget.widget-category .widget-category-list li a, .widget.widget-category ul li a {
    color: #000000 !important; }
    .widget.widget-category .widget-category-list li a:hover, .widget.widget-category ul li a:hover {
      color: #f53f3f !important; }
    .widget.widget-category .widget-category-list li a.current, .widget.widget-category ul li a.current {
      color: #ffffff !important; }
  .widget.widget-tag .widget-tag-list {
    list-style: none !important;
    margin: 0 !important;
