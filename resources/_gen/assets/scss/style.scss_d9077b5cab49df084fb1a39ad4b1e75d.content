      color: rgba(255, 255, 255, 0.8); }
      .footer .copyright a:hover {
        color: #ffffff; }

:root {
  --quko-ink: #12151c;
  --quko-ink-soft: #252b36;
  --quko-red: #e8383f;
  --quko-red-dark: #b71925;
  --quko-coral: #ff696d;
  --quko-blue: #68c7dc;
  --quko-mist: #f3f5f7;
  --quko-line: #dfe3e8;
  --quko-muted: #626b78;
  --quko-white: #ffffff;
  --quko-radius: 24px;
  --quko-shadow: 0 24px 70px rgba(18, 21, 28, 0.12); }

html {
  scroll-behavior: smooth; }

body {
  color: var(--quko-ink);
  background: var(--quko-white);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased; }

body,
button,
input,
textarea,
select {
  font-family: "Inter", sans-serif; }

h1,
h2,
h3,
h4,
h5,
h6 {
  color: var(--quko-ink);
  font-family: "Inter", sans-serif;
  letter-spacing: -0.035em; }

p {
  color: var(--quko-muted);
  line-height: 1.72; }

a {
  transition: color .2s ease, background-color .2s ease, border-color .2s ease, transform .2s ease; }

.container {
  width: calc(100% - 40px);
  max-width: 1180px; }

.quko-section {
  padding: 104px 0; }

.quko-section-sm {
  padding: 72px 0; }

.quko-section-muted {
  background: var(--quko-mist); }

.quko-section-dark {
  background: #314955;
  color: var(--quko-white); }

.quko-section-dark h2,
.quko-section-dark h3,
.quko-section-dark p {
  color: var(--quko-white); }

.quko-section-dark p {
  opacity: .82; }

.quko-section-dark .quko-card {
  border-color: rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.08); }

.quko-section-dark .quko-card:hover {
  border-color: rgba(255, 255, 255, 0.28);
  box-shadow: 0 18px 48px rgba(19, 34, 42, 0.2); }

.quko-section-dark .quko-card h3,
.quko-section-dark .quko-card p {
  color: var(--quko-white); }

.quko-section-dark .quko-check-list li {
  color: rgba(255, 255, 255, 0.84); }

.quko-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  margin: 0 0 18px;
  color: var(--quko-red-dark);
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .14em;
  line-height: 1.2;
  text-transform: uppercase;
  white-space: normal; }

.quko-eyebrow:before {
  width: 28px;
  height: 2px;
  background: var(--quko-red);
  content: ""; }

.quko-section-dark .quko-eyebrow {
  color: #ff989b; }

.quko-section-title {
  max-width: 760px;
  margin-bottom: 48px; }

.quko-section-title.center {
  margin-right: auto;
  margin-left: auto;
  text-align: center; }

.quko-section-title h2 {
  margin: 0 0 18px;
  font-size: clamp(34px, 4vw, 58px);
  font-weight: 750;
  line-height: 1.06; }

.quko-section-title p {
  max-width: 680px;
  margin: 0;
  font-size: 18px; }

.quko-section-title.center p {
  margin-right: auto;
  margin-left: auto; }

.btn-quko,
.btn-quko-outline,
.btn-quko-light {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 50px;
  padding: 0 24px;
  border: 1px solid transparent;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 750;
  letter-spacing: .01em;
  text-decoration: none; }

.btn-quko {
  background: var(--quko-red);
  color: var(--quko-white) !important;
  box-shadow: 0 12px 30px rgba(232, 56, 63, 0.25); }

.btn-quko:hover,
.btn-quko:focus {
  background: var(--quko-red-dark);
  color: var(--quko-white);
  transform: translateY(-2px); }

.btn-quko-outline {
  border-color: rgba(18, 21, 28, 0.18);
  color: var(--quko-ink) !important; }

.btn-quko-outline:hover,
.btn-quko-outline:focus {
  border-color: var(--quko-ink);
  background: var(--quko-ink);
  color: var(--quko-white) !important; }

.btn-quko-light {
  background: var(--quko-white);
  color: var(--quko-ink) !important; }

.quko-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 30px; }

/* Navigation */
.navigation {
  position: sticky;
  top: 0;
  z-index: 1000;
  padding: 12px 0;
  border-bottom: 1px solid rgba(18, 21, 28, 0.07);
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(18px); }

.navigation .container-fluid {
  width: calc(100% - 32px);
  max-width: 1280px; }

.navigation .navbar {
  min-height: 56px;
  margin: 0; }

.navigation .navbar-brand {
  height: 56px;
  padding: 7px 15px;
  border-radius: 12px;
  background: var(--quko-white); }

.navigation .navbar-brand img {
  max-height: 42px;
  width: auto; }

.navigation .navbar-nav > li > a {
  padding: 19px 13px;
  color: var(--quko-ink-soft);
  font-size: 14px;
  font-weight: 650; }

.navigation .navbar-nav > li > a:hover,
.navigation .navbar-nav > li > a:focus,
.navigation .navbar-nav > li > a.current {
  background: transparent;
  color: var(--quko-red); }

.navigation .dropdown-menu {
  padding: 10px;
  border: 1px solid var(--quko-line);
  border-radius: 16px;
  box-shadow: var(--quko-shadow); }

.navigation .dropdown-menu > li > a {
  padding: 10px 13px;
  border-radius: 10px;
  font-weight: 600; }

.navigation .dropdown-menu > li > a:hover {
  background: var(--quko-mist);
  color: var(--quko-red); }

.navigation .nav-cta > a {
  margin: 8px 0 8px 8px;
  padding: 11px 18px !important;
  border-radius: 999px;
  background: var(--quko-red) !important;
  color: var(--quko-white) !important; }

.navigation .nav-cloud > a {
  margin: 8px 0 8px 8px;
  padding: 10px 17px !important;
  border: 1px solid rgba(232, 56, 63, 0.38);
  border-radius: 999px;
  background: var(--quko-white) !important;
  color: var(--quko-red-dark) !important; }

.navigation .nav-cloud > a:hover,
.navigation .nav-cloud > a:focus {
  border-color: var(--quko-red);
  background: rgba(232, 56, 63, 0.06) !important;
  color: var(--quko-red-dark) !important; }

@media (min-width: 992px) {
  .navigation .navbar {
    display: flex;
    align-items: center; }
  .navigation .navbar-header {
    flex: 0 0 auto; }
  .navigation .navbar-collapse {
    display: flex !important;
    align-items: center;
    flex: 1 1 auto;
    padding-right: 0; }
  .navigation .navbar-nav {
    display: flex;
    align-items: center;
    float: none !important;
    margin: 0 0 0 auto; }
  .navigation .navbar-nav > li {
    display: flex;
    align-items: center;
    float: none; } }

#select-language {
  height: 38px;
  margin: 9px 4px 9px 10px;
  padding: 0 28px 0 12px;
  border: 1px solid var(--quko-line);
  border-radius: 999px;
  background-color: var(--quko-white);
  color: var(--quko-ink);
  font-size: 12px;
  font-weight: 700; }

/* Homepage hero */
.quko-hero {
  position: relative;
  overflow: hidden;
  padding: 96px 0 88px;
  background: radial-gradient(circle at 78% 15%, rgba(104, 199, 220, 0.24), transparent 31%), radial-gradient(circle at 12% 75%, rgba(232, 56, 63, 0.15), transparent 28%), linear-gradient(145deg, #f8f9fa 0%, #ffffff 54%, #f2f5f7 100%); }

.quko-hero:after {
  position: absolute;
  right: -120px;
  bottom: -180px;
  width: 520px;
  height: 520px;
  border: 1px solid rgba(18, 21, 28, 0.08);
  border-radius: 50%;
  content: ""; }

.quko-hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.02fr) minmax(360px, 0.98fr);
  align-items: center;
  gap: 72px; }

.quko-hero-copy {
  position: relative;
  z-index: 2;
  min-width: 0; }

.quko-hero h1 {
  margin: 0;
  font-size: clamp(48px, 6vw, 82px);
  font-weight: 780;
  line-height: .98; }

.quko-hero-copy > p {
  max-width: 620px;
  margin: 26px 0 0;
  font-size: 19px; }

.quko-hero-visual {
  position: relative;
  z-index: 2;
  min-width: 0; }

.quko-hero-visual img {
  width: 100%;
  border-radius: 28px;
  box-shadow: var(--quko-shadow); }

.quko-hero-badge {
  position: static;
  max-width: none;
  margin-top: 14px;
  padding: 18px 20px;
  border: 1px solid var(--quko-line);
  border-radius: 18px;
  background: var(--quko-white);
  color: var(--quko-ink);
  box-shadow: 0 12px 35px rgba(18, 21, 28, 0.08); }

.quko-hero-badge strong {
  display: block;
  margin-bottom: 4px;
  color: var(--quko-ink);
  font-size: 18px; }

.quko-hero-badge span {
  color: var(--quko-muted);
  font-size: 12px;
  line-height: 1.4; }

.quko-audience-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid var(--quko-line);
  border-bottom: 1px solid var(--quko-line); }

.quko-audience {
  padding: 28px;
  border-right: 1px solid var(--quko-line); }

.quko-audience:last-child {
  border-right: 0; }

.quko-audience i {
  margin-right: 10px;
  color: var(--quko-red); }

.quko-audience strong {
  font-size: 15px; }

.quko-grid-3,
.quko-grid-4 {
  display: grid;
  gap: 24px; }

.quko-grid-3 {
  grid-template-columns: repeat(3, minmax(0, 1fr)); }

.quko-grid-4 {
  grid-template-columns: repeat(4, minmax(0, 1fr)); }

.quko-card {
  height: 100%;
  padding: 32px;
  border: 1px solid var(--quko-line);
  border-radius: var(--quko-radius);
  background: var(--quko-white);
  transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease; }

.quko-card:hover {
  border-color: rgba(232, 56, 63, 0.35);
  box-shadow: 0 18px 48px rgba(18, 21, 28, 0.09);
  transform: translateY(-4px); }

.quko-card-number,
.quko-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  margin-bottom: 26px;
  border-radius: 15px;
  background: rgba(232, 56, 63, 0.1);
  color: var(--quko-red-dark);
  font-size: 18px;
  font-weight: 800; }

.quko-card h3 {
  margin: 0 0 12px;
  font-size: 24px;
  font-weight: 740; }

.quko-card p {
  margin: 0; }

.quko-card-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 24px;
  color: var(--quko-red-dark);
  font-weight: 750; }

.quko-product-card {
  position: relative;
  min-height: 440px;
  overflow: hidden;
  padding: 0;
  background: #3a5360; }

.quko-product-card img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  opacity: .88; }

.quko-product-card-content {
  padding: 28px;
  background: #3a5360; }

.quko-product-card h3,
.quko-product-card p {
  color: var(--quko-white); }

.quko-product-card p {
  opacity: .66; }

.quko-product-card .quko-card-link {
  color: #ff989b; }

.quko-metric-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  overflow: hidden;
  border: 1px solid var(--quko-line);
  border-radius: var(--quko-radius);
  background: var(--quko-white); }

.quko-metric {
  padding: 30px;
  border-right: 1px solid var(--quko-line); }

.quko-metric:last-child {
  border-right: 0; }

.quko-metric strong {
  display: block;
  margin-bottom: 5px;
  color: var(--quko-ink);
  font-size: 26px;
  line-height: 1.1; }

.quko-metric span {
  color: var(--quko-muted);
  font-size: 13px; }

.quko-showcase {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
  align-items: center;
  gap: 72px; }

.quko-showcase.reverse .quko-showcase-media {
  order: 2; }

.quko-showcase-media {
  position: relative;
  overflow: hidden;
  padding: 16px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 30px;
  background: #405b68;
  box-shadow: var(--quko-shadow); }

.quko-showcase-media.light {
  border-color: var(--quko-line);
  background: var(--quko-mist); }

.quko-showcase-media img {
  width: 100%;
  border-radius: 18px; }

.quko-check-list {
  display: grid;
  gap: 15px;
  margin: 28px 0 0;
  padding: 0;
  list-style: none; }

.quko-check-list li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  color: var(--quko-muted); }

.quko-check-list i {
  margin-top: 4px;
  color: var(--quko-red); }

.quko-chip-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px; }

.quko-chip {
  padding: 11px 17px;
  border: 1px solid var(--quko-line);
  border-radius: 999px;
  background: var(--quko-white);
  color: var(--quko-ink-soft);
  font-size: 13px;
  font-weight: 700; }

.quko-cta {
  position: relative;
  overflow: hidden;
  padding: 72px;
  border-radius: 34px;
  background: radial-gradient(circle at 88% 18%, rgba(104, 199, 220, 0.3), transparent 29%), var(--quko-ink); }

.quko-cta:after {
  position: absolute;
  right: -90px;
  bottom: -130px;
  width: 330px;
  height: 330px;
  border: 1px solid rgba(255, 255, 255, 0.13);
  border-radius: 50%;
  content: ""; }

.quko-cta-content {
  position: relative;
  z-index: 2;
  max-width: 720px; }

.quko-cta h2 {
  margin: 0 0 16px;
  color: var(--quko-white);
  font-size: clamp(36px, 4vw, 56px);
  font-weight: 760;
  line-height: 1.05; }

.quko-cta p {
  max-width: 620px;
  margin: 0;
  color: rgba(255, 255, 255, 0.68);
  font-size: 18px; }

/* Product and standard page heroes */
.quko-page-hero {
  padding: 90px 0 80px;
  background: var(--quko-mist); }

.quko-page-hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(360px, 1fr);
  align-items: center;
  gap: 70px; }

.quko-page-hero h1 {
  margin: 0;
  font-size: clamp(48px, 6vw, 76px);
  font-weight: 780;
  line-height: 1; }

.quko-page-hero p {
  max-width: 620px;
  margin: 24px 0 0;
  font-size: 19px; }

.quko-hero-copy p,
.quko-page-hero p,
.quko-card p {
  overflow-wrap: anywhere; }

.quko-page-hero img {
  width: 100%;
  max-height: 520px;
  border-radius: 28px;
  box-shadow: var(--quko-shadow);
  object-fit: cover; }

.quko-page-title {
  padding: 76px 0 58px;
  background: radial-gradient(circle at 80% 20%, rgba(104, 199, 220, 0.18), transparent 28%), var(--quko-mist);
  text-align: center; }

.quko-page-title h1 {
  margin: 0;
  font-size: clamp(44px, 5vw, 68px);
  font-weight: 770; }

.quko-page-title p {
  max-width: 660px;
  margin: 18px auto 0;
  font-size: 18px; }

.quko-copy-grid {
  display: grid;
  grid-template-columns: .8fr 1.2fr;
  gap: 80px; }

.quko-copy-grid h2 {
  margin: 0;
  font-size: clamp(34px, 4vw, 52px);
  font-weight: 760;
  line-height: 1.08; }

.quko-copy-grid .quko-copy p {
  font-size: 18px; }

/* Existing supporting pages */
.page-title {
  padding: 72px 0;
  background-color: var(--quko-mist);
  background-blend-mode: soft-light; }

.page-title .block h1 {
  font-size: clamp(42px, 5vw, 64px);
  font-weight: 760; }

.contact-form,
.pricing-table,
.faq,
.page-wrapper,
.blog {
  background: var(--quko-white); }

.contact-form .form-control,
.newsletter-form .form-control {
  min-height: 52px;
  border: 1px solid var(--quko-line);
  border-radius: 12px;
  box-shadow: none; }

.contact-form textarea.form-control {
  min-height: 140px; }

.contact-form .btn,
.newsletter-form .btn {
  border-radius: 999px;
  background: var(--quko-red); }

.post,
.pricing-item,
.faq .panel {
  border: 1px solid var(--quko-line);
  border-radius: 18px;
  box-shadow: none; }

/* Footer */
.footer {
  padding: 72px 0 34px;
  background: #0c0e13; }

.quko-footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: 60px;
  margin-bottom: 52px; }

.quko-footer-brand img {
  width: 150px;
  margin: 0;
  filter: none; }

.quko-footer-brand > a {
  display: inline-flex;
  margin-bottom: 22px;
  padding: 12px 16px;
  border-radius: 15px;
  background: var(--quko-white); }

.quko-footer-brand p {
  max-width: 390px;
  color: rgba(255, 255, 255, 0.58); }

.quko-footer-column h3 {
  margin: 0 0 18px;
  color: var(--quko-white);
  font-size: 14px;
  letter-spacing: .08em;
  text-transform: uppercase; }

.quko-footer-column ul {
  margin: 0;
  padding: 0;
  list-style: none; }

.quko-footer-column li {
  margin-bottom: 11px; }

.quko-footer-column a {
  color: rgba(255, 255, 255, 0.62); }

.quko-footer-column a:hover {
  color: var(--quko-white); }

.quko-footer-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 28px;
  border-top: 1px solid rgba(255, 255, 255, 0.1); }

.quko-footer-bottom p {
  margin: 0;
  color: rgba(255, 255, 255, 0.4);
  font-size: 12px; }

.quko-socials {
  display: flex;
  gap: 10px; }

.quko-socials a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 50%;
  color: var(--quko-white); }

[data-reveal] {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity .65s ease, transform .65s ease; }

[data-reveal].revealed {
  opacity: 1;
  transform: none; }

@media (max-width: 991px) {
  .quko-section {
    padding: 80px 0; }
  .quko-hero-grid,
  .quko-page-hero-grid,
  .quko-showcase,
  .quko-copy-grid {
    grid-template-columns: 1fr;
    gap: 44px; }
  .quko-showcase.reverse .quko-showcase-media {
    order: 0; }
  .quko-grid-4,
  .quko-audience-row,
  .quko-metric-strip {
    grid-template-columns: repeat(2, 1fr); }
  .quko-grid-3 {
    grid-template-columns: 1fr; }
  .quko-product-card {
    min-height: 0; }
  .quko-audience:nth-child(2),
  .quko-metric:nth-child(2) {
    border-right: 0; }
  .quko-audience:nth-child(-n+2),
  .quko-metric:nth-child(-n+2) {
    border-bottom: 1px solid var(--quko-line); }
  .navigation .navbar-collapse {
    margin-top: 10px;
    border-top: 1px solid var(--quko-line);
    background: var(--quko-white); }
  .navigation .navbar-header {
    float: none; }
  .navigation .navbar-toggle {
    display: block;
    float: right;
    margin: 10px 0 0;
    padding: 10px;
    border: 1px solid var(--quko-line);
    border-radius: 10px;
    background: var(--quko-white); }
  .navigation .navbar-toggle .icon-bar {
    width: 22px;
    height: 2px;
    background: var(--quko-ink); }
  .navigation .navbar-collapse.collapse {
    display: none !important; }
  .navigation .navbar-collapse.collapse.in {
    display: block !important; }
  .navigation .navbar-nav {
    float: none !important;
    margin: 8px 0; }
  .navigation .navbar-nav > li {
    float: none; }
  .navigation .navbar-nav > li > a {
    padding: 13px 10px; }
  .navigation .nav-cta > a {
    display: inline-flex;
    margin-left: 0; }
  #select-language {
    margin-left: 0; } }

@media (max-width: 767px) {
  .container,
  .navigation .container-fluid {
    width: calc(100% - 28px);
    max-width: 1180px; }
  .quko-section {
    padding: 64px 0; }
  .quko-section-sm {
    padding: 52px 0; }
  .quko-hero,
  .quko-page-hero {
    padding: 64px 0; }
  .quko-hero h1,
  .quko-page-hero h1 {
    font-size: 46px; }
  .quko-hero-grid,
  .quko-page-hero-grid {
    grid-template-columns: 1fr; }
  .quko-actions {
    align-items: stretch;
    flex-direction: column; }
  .quko-actions .btn-quko,
  .quko-actions .btn-quko-outline,
  .quko-actions .btn-quko-light {
    width: 100%; }
  .quko-grid-4,
  .quko-audience-row,
  .quko-metric-strip {
    grid-template-columns: 1fr; }
  .quko-audience,
  .quko-metric {
    border-right: 0;
    border-bottom: 1px solid var(--quko-line); }
  .quko-audience:last-child,
  .quko-metric:last-child {
    border-bottom: 0; }
  .quko-card {
    padding: 26px; }
  .quko-product-card {
    padding: 0; }
  .quko-cta {
    padding: 42px 28px;
    border-radius: 26px; }
  .quko-footer-grid {
    grid-template-columns: 1fr;
    gap: 34px; }
  .quko-footer-bottom {
    align-items: flex-start;
    flex-direction: column;
    gap: 20px; } }

@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto; }
  *,
  *:before,
  *:after {
    animation-duration: .01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: .01ms !important; }
  [data-reveal] {
    opacity: 1;
    transform: none; } }
