        font-weight: 500 !important;
        text-decoration: none !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
        letter-spacing: 0.025em; }
        .widget.widget-tag .widget-tag-list li a:hover {
          color: #f53f3f !important;
          background: #ffffff !important;
          border-color: #f53f3f !important;
          transform: translateY(-2px) !important;
          box-shadow: 0 4px 8px -1px rgba(245, 63, 63, 0.25); }
        .widget.widget-tag .widget-tag-list li a:active {
          transform: translateY(0) !important;
          box-shadow: 0 2px 4px -1px rgba(245, 63, 63, 0.2); }
      .widget.widget-tag .widget-tag-list li a.current {
        color: #ffffff !important;
        background: #f53f3f !important;
        border-color: #f53f3f !important;
        box-shadow: 0 4px 6px -1px rgba(245, 63, 63, 0.3);
        pointer-events: none;
        cursor: default;
        transform: none !important; }
  .widget.widget-tag .widget-tag-list li a, .widget.widget-tag ul li a {
    color: #000000 !important; }
    .widget.widget-tag .widget-tag-list li a:hover, .widget.widget-tag ul li a:hover {
      color: #f53f3f !important; }
    .widget.widget-tag .widget-tag-list li a.current, .widget.widget-tag ul li a.current {
      color: #ffffff !important; }

@media (max-width: 768px) {
  .sidebar {
